<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MenuPrincipalActivity">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/idCardProdutos"
        android:layout_width="200dp"
        android:layout_height="250dp"
        android:layout_margin="10dp"
        android:backgroundTint="#016349"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_margin="10dp"
                android:scaleType="centerCrop"
                android:src="@drawable/arroz_japones" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Produtos"
                android:textColor="#fff"
                android:textSize="30sp" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/idCardPedidos"
        android:layout_width="200dp"
        android:layout_height="250dp"
        android:layout_margin="10dp"
        android:backgroundTint="#C89764"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_margin="10dp"
                android:background="#fff"
                android:scaleType="centerCrop"
                android:src="@drawable/pacotes" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Pedidos"
                android:textColor="#fff"
                android:textSize="30sp" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>


</LinearLayout>